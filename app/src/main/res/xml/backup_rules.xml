<?xml version="1.0" encoding="utf-8"?><!--
   Auto Backup rules for devices on API < 31.
   See https://developer.android.com/guide/topics/data/autobackup

   The 10-day blockade ledger lives in app-private files (filesDir/blockade.json). Including it here
   means it is uploaded to the user's Google cloud backup and restored on reinstall, giving the
   blockade best-effort uninstall survival without any storage permission.
-->
<full-backup-content>
    <include domain="file" path="blockade.json"/>
    <include domain="file" path="datastore/tempo_settings.preferences_pb"/>
</full-backup-content>
